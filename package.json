{
  "name": "summer-slam",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node -e \"const fs=require('fs'),p='dist/sw.js',t=Date.now();fs.writeFileSync(p,fs.readFileSync(p,'utf8').replace(/summer-slam-v[\\w]+/,'summer-slam-'+t))\"",
    "preview": "vite preview",
    "pages:dev": "wrangler pages dev --proxy 5173 --compatibility-date=2024-09-23"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "marked": "^18.0.3",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.3.0",
    "wrangler": "^3.100.0"
  }
}
